---
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card";
import { Button } from "@/components/ui/button";

interface Props {
  tier: 'standard' | 'business' | 'enterprise';
  title: string;
  price: string;
  description: string;
  features: string[];
  popular?: boolean;
  priceSuffix?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  tier,
  title,
  price,
  description,
  features,
  popular = false,
  priceSuffix = '/proyecto',
  ctaHref = '/contacto',
  ctaLabel = 'Solicitar este plan',
} = Astro.props;
---

<Card className={`relative h-full rounded-xl ${popular ? 'border-primary shadow-lg shadow-zinc-900/10' : ''}`}>
  {popular && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="bg-primary text-primary-foreground px-4 py-1 rounded-full text-sm font-semibold">
        Mas Popular
      </span>
    </div>
  )}

  <CardHeader className="gap-4">
    <CardTitle className="text-xl sm:text-2xl">{title}</CardTitle>
    <CardDescription>{description}</CardDescription>
    <div class="mt-2 flex items-end gap-1">
      <span class="text-3xl sm:text-4xl font-bold leading-none">{price}</span>
      <span class="text-muted-foreground pb-1 text-sm">{priceSuffix}</span>
    </div>
  </CardHeader>

  <CardContent className="flex-1">
    <ul class="space-y-3">
      {features.map((feature) => (
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-primary mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm sm:text-[15px] leading-relaxed">{feature}</span>
        </li>
      ))}
    </ul>
  </CardContent>

  <CardFooter className="mt-auto">
    <a href={ctaHref} class="w-full">
      <Button client:load className="w-full min-h-11 text-sm sm:text-base" variant={popular ? 'default' : 'outline'}>
        {ctaLabel}
      </Button>
    </a>
  </CardFooter>
</Card>
