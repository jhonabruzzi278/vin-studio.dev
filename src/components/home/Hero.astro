---
import { Button } from "@/components/ui/button";
---

<section class="relative flex items-center bg-white min-h-[calc(100svh-4rem)] overflow-hidden">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(24,24,27,0.04),transparent_45%)]"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-zinc-200"></div>

  <div class="container relative mx-auto px-4 py-16 sm:py-24 lg:py-28">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-start gap-6 lg:gap-16">
        <div class="hidden lg:block pt-3">
          <div class="w-px h-28 bg-zinc-900"></div>
        </div>

        <div class="flex-1 space-y-8 sm:space-y-10">
          <div class="space-y-5">
            <p class="text-xs sm:text-sm font-semibold uppercase tracking-[0.25em] text-zinc-500">
              Estudio digital para empresas que quieren resultados
            </p>

            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-extrabold text-zinc-900 leading-[0.9] tracking-tighter">
              DE IDEA<br />
              <span class="block">A REALIDAD.</span>
            </h1>

            <p class="text-base sm:text-lg md:text-xl text-zinc-500 max-w-2xl leading-relaxed">
              Desarrollo web y consultoria tecnologica con precision tecnica.
              <br class="hidden sm:block" />
              Sin ruido. Solo resultados.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-stretch sm:items-center sm:max-w-none max-w-sm">
            <a href="/contacto" class="block w-full sm:w-auto">
              <Button client:load size="lg" className="w-full sm:w-auto">
                Empezar Proyecto
              </Button>
            </a>
            <a href="/portafolio" class="block w-full sm:w-auto">
              <Button client:load variant="outline" size="lg" className="w-full sm:w-auto">
                Ver Portafolio
              </Button>
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-x-6 gap-y-2 pt-2 text-xs sm:text-sm text-zinc-500">
            <span>Respuesta inicial en 48h</span>
            <span class="hidden sm:inline">|</span>
            <span>Servicios 100% online</span>
            <span class="hidden sm:inline">|</span>
            <span>Procesos claros de inicio a entrega</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
