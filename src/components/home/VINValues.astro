---
const values = [
  {
    key: "01",
    letter: "V",
    title: "Vision",
    tagline: "Pensamos primero en negocio, despues en codigo.",
    description:
      "Leemos objetivos, margenes y operacion antes de tocar una linea tecnica. Asi construimos soluciones que impactan resultados reales.",
    outcomes: [
      "Ruta clara de producto y tecnologia",
      "Priorizacion por impacto comercial",
      "Decisiones tecnicas con contexto de negocio",
    ],
  },
  {
    key: "02",
    letter: "I",
    title: "Integridad",
    tagline: "Lo que prometemos, lo documentamos y lo cumplimos.",
    description:
      "Trabajamos con transparencia total: alcance, tiempos y costos visibles desde el inicio. Sin promesas infladas ni sorpresas al final.",
    outcomes: [
      "Hitos y entregables verificables",
      "Comunicacion directa y frecuente",
      "Expectativas alineadas desde el dia uno",
    ],
  },
  {
    key: "03",
    letter: "N",
    title: "Notoriedad",
    tagline: "Construimos presencia digital que se recuerda.",
    description:
      "Cada proyecto combina estetica, rendimiento y claridad de mensaje para que tu marca destaque y se vea profesional en cada punto de contacto.",
    outcomes: [
      "Experiencias visuales memorables",
      "Interfaces claras y rapidas",
      "Propuesta digital que diferencia tu marca",
    ],
  },
];
---

<section class="relative bg-white py-16 sm:py-24 lg:py-28 overflow-hidden">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_bottom,transparent,rgba(24,24,27,0.02),transparent)]"></div>

  <div class="container mx-auto px-4 relative">
    <div class="max-w-6xl mx-auto">
      <div class="text-center animate-slide-up">
        <p class="text-xs sm:text-sm font-semibold uppercase tracking-[0.22em] text-zinc-500">
          Nuestros valores
        </p>
        <h2 class="mt-4 text-4xl sm:text-6xl lg:text-7xl font-black tracking-tight text-zinc-900 leading-[0.95]">
          VISION. INTEGRIDAD. NOTORIEDAD.
        </h2>
        <p class="mt-6 max-w-2xl mx-auto text-sm sm:text-base text-zinc-600 leading-relaxed">
          No son palabras decorativas. Son criterios de trabajo para disenar, implementar y operar soluciones que hagan crecer a nuestros clientes.
        </p>
      </div>

      <ol class="mt-12 sm:mt-16 border-y border-zinc-200 divide-y divide-zinc-200">
        {values.map((value, index) => (
          <li
            class="group relative grid lg:grid-cols-[96px_1fr_260px] gap-6 lg:gap-8 py-8 sm:py-10 lg:py-12 animate-slide-up"
            style={`animation-delay: ${120 + index * 120}ms`}
          >
            <div class="hidden lg:flex items-start justify-center">
              <span class="text-[5rem] leading-none font-black text-zinc-100 group-hover:text-zinc-200 transition-colors duration-300 select-none">
                {value.letter}
              </span>
            </div>

            <div class="space-y-4 lg:space-y-5">
              <div class="flex items-center gap-3 sm:gap-4">
                <span class="text-[11px] sm:text-xs font-bold tracking-[0.28em] uppercase text-zinc-400">
                  {value.key}
                </span>
                <div class="h-px flex-1 bg-zinc-200 group-hover:bg-zinc-900 transition-colors duration-300"></div>
              </div>

              <h3 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-zinc-900">
                {value.title}
              </h3>

              <p class="text-base sm:text-lg text-zinc-900 font-medium leading-relaxed">
                {value.tagline}
              </p>

              <p class="text-sm sm:text-base text-zinc-600 leading-relaxed max-w-2xl">
                {value.description}
              </p>
            </div>

            <div class="lg:pt-10">
              <p class="text-[11px] sm:text-xs font-semibold uppercase tracking-[0.22em] text-zinc-500 mb-3">
                Como se traduce
              </p>
              <ul class="space-y-2.5">
                {value.outcomes.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-zinc-600 group-hover:text-zinc-800 transition-colors duration-300">
                    <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-zinc-900"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>

      <div class="mt-10 sm:mt-12 text-center animate-slide-up" style="animation-delay: 520ms">
        <p class="inline-flex items-center gap-3 text-xs sm:text-sm font-semibold tracking-[0.18em] uppercase text-zinc-900">
          <span class="h-px w-10 sm:w-14 bg-zinc-900"></span>
          Asi trabajamos en VIN Studio
          <span class="h-px w-10 sm:w-14 bg-zinc-900"></span>
        </p>
      </div>
    </div>
  </div>
</section>
