<script>
  // soporte táctil y teclado: alterna la clase is-flipped en la tarjeta activa
  const cards = document.querySelectorAll('.flip-card');
  cards.forEach((card) => {
    // click/tap: alterna flip solo en la tarjeta clickeada
    card.addEventListener('click', () => {
      card.classList.toggle('is-flipped');
    });
    // teclado: Enter o Space
    card.addEventListener('keydown', (e) => {
      if (!(e instanceof KeyboardEvent)) return;
      const key = e.key;
      if (key === 'Enter' || key === ' ') {
        e.preventDefault();
        card.classList.toggle('is-flipped');
      }
    });
  });
</script>
