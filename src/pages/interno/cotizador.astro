---
import Layout from "@/layouts/Layout.astro";
import CotizadorIsland from "@/components/interno/CotizadorIsland.tsx";

export const prerender = false;

const plans = [
  { id: "express", name: "Plan Express", price: 99990 },
  { id: "completa", name: "Plan Completa", price: 249990 },
  { id: "pro", name: "Plan Pro", price: 399990 },
  { id: "elite", name: "Plan Elite", price: 649990 },
];

const extras = [
  { id: "productos_extra", name: "Carga extra de productos", price: 50000 },
  { id: "integracion_adicional", name: "Integraciones adicionales", price: 40000 },
  { id: "desarrollo_medida", name: "Desarrollo a medida", price: 80000 },
  { id: "fotografia_adicional", name: "Fotografia adicional", price: 60000 },
];
---

<Layout
  title="Cotizador Interno | VIN Studio"
  description="Herramienta interna para generar cotizaciones ecommerce de forma rápida y consistente."
  noindex={true}
>
  <section class="container mx-auto px-3 sm:px-4 py-8 sm:py-14">
      <div class="max-w-7xl mx-auto">
        <div class="mb-8 sm:mb-10">
          <div>
            <h1 class="text-3xl sm:text-4xl font-bold text-zinc-900 mb-2">Cotizador Interno</h1>
            <p class="text-zinc-600 max-w-3xl">
              Selecciona plan, extras y obtendrás un resumen listo para enviar al cliente.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 lg:gap-8 items-start">
          <div class="border rounded-2xl bg-white p-4 sm:p-6 lg:p-8 space-y-6 shadow-sm">
            <h2 class="text-xl font-semibold text-zinc-900">1) Datos del cliente</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-zinc-900 mb-2" for="clienteNombre">Nombre</label>
                <input id="clienteNombre" type="text" class="w-full h-10 px-3 border border-zinc-300 rounded-md" placeholder="Nombre cliente" />
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-900 mb-2" for="clienteEmpresa">Empresa</label>
                <input id="clienteEmpresa" type="text" class="w-full h-10 px-3 border border-zinc-300 rounded-md" placeholder="Empresa" />
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-900 mb-2" for="clienteEmail">Email</label>
                <input id="clienteEmail" type="email" class="w-full h-10 px-3 border border-zinc-300 rounded-md" placeholder="email@cliente.com" />
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-900 mb-2" for="clienteWhatsapp">WhatsApp</label>
                <input id="clienteWhatsapp" type="text" class="w-full h-10 px-3 border border-zinc-300 rounded-md" placeholder="+56 9 ..." />
              </div>
            </div>

            <h2 class="text-xl font-semibold text-zinc-900 pt-2">2) Plan de implementación</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {plans.map((plan) => (
                <label class="border rounded-lg p-4 cursor-pointer hover:border-zinc-900 transition-colors">
                  <input type="radio" name="plan" value={plan.id} data-plan-price={plan.price} class="mr-2" />
                  <span class="font-medium text-zinc-900">{plan.name}</span>
                  <span class="block text-sm text-zinc-600 mt-1">{plan.price.toLocaleString("es-CL")} CLP</span>
                </label>
              ))}
            </div>

            <h2 class="text-xl font-semibold text-zinc-900 pt-2">3) Extras</h2>
            <div class="space-y-3">
              {extras.map((extra) => (
                <label class="flex items-start gap-3 border rounded-lg p-4 cursor-pointer hover:border-zinc-900 transition-colors">
                  <input type="checkbox" value={extra.id} data-extra-price={extra.price} class="mt-1" />
                  <span>
                    <span class="block font-medium text-zinc-900">{extra.name}</span>
                    <span class="block text-sm text-zinc-600">+ {extra.price.toLocaleString("es-CL")} CLP</span>
                  </span>
                </label>
              ))}
            </div>

            <div class="border rounded-lg p-4 bg-zinc-50">
              <label class="flex items-start gap-3 cursor-pointer">
                <input id="sinPasarela" type="checkbox" class="mt-1" />
                <span>
                  <span class="block font-medium text-zinc-900">Sin pasarela de pago</span>
                  <span class="block text-sm text-zinc-600">Aplicar descuento de - $100.000 CLP</span>
                  <span id="sinPasarelaHint" class="block text-xs text-zinc-500 mt-1">Disponible para Plan Completa, Pro y Elite.</span>
                </span>
              </label>
            </div>

            <div class="border rounded-lg p-4 bg-white">
              <p class="text-sm font-semibold text-zinc-900 mb-2">Continuidad mensual (opcional en cotización)</p>
              <label class="flex items-start gap-3 cursor-pointer">
                <input id="incluirSoporte" type="checkbox" class="mt-1" checked />
                <span>
                  <span class="block font-medium text-zinc-900">Incluir Soporte+ mensual: $100.000 CLP</span>
                  <span class="block text-sm text-zinc-600">Detalle: $65.000 plataforma + $35.000 soporte.</span>
                </span>
              </label>
            </div>

            <button id="btnCalcular" type="button" class="inline-flex items-center justify-center h-11 w-full sm:w-auto px-6 text-sm font-semibold bg-zinc-900 text-white border border-zinc-900 hover:bg-zinc-800 transition-colors">
              Calcular cotización
            </button>
          </div>

          <div id="quoteCapture" class="border rounded-2xl bg-zinc-50 p-4 sm:p-6 lg:p-8 space-y-6 shadow-sm lg:sticky lg:top-6">
            <h2 class="text-xl font-semibold text-zinc-900">4) Resumen de cotización</h2>

            <div class="space-y-2 text-sm sm:text-base">
              <p><span class="font-semibold text-zinc-900">Cliente:</span> <span id="outCliente" class="text-zinc-600">-</span></p>
              <p><span class="font-semibold text-zinc-900">Empresa:</span> <span id="outEmpresa" class="text-zinc-600">-</span></p>
              <p><span class="font-semibold text-zinc-900">Plan:</span> <span id="outPlan" class="text-zinc-600">-</span></p>
              <p><span class="font-semibold text-zinc-900">Implementación:</span> <span id="outImplementacion" class="text-zinc-600">$0 CLP</span></p>
              <p><span class="font-semibold text-zinc-900">Extras:</span> <span id="outExtras" class="text-zinc-600">$0 CLP</span></p>
              <p><span class="font-semibold text-zinc-900">Descuento:</span> <span id="outDescuento" class="text-zinc-600">$0 CLP</span></p>
              <p><span class="font-semibold text-zinc-900">Motivo descuento:</span> <span id="outMotivoDescuento" class="text-zinc-600">-</span></p>
              <p class="text-lg pt-2"><span class="font-bold text-zinc-900">Total inicial:</span> <span id="outTotal" class="font-bold text-zinc-900">$0 CLP</span></p>
            </div>

            <div class="border-t pt-4 text-sm sm:text-base text-zinc-700 space-y-2">
              <p class="font-semibold text-zinc-900">Alcance y limites del plan</p>
              <ul id="outScopeList" class="list-disc list-inside space-y-1 text-zinc-600">
                <li>Selecciona un plan para ver detalle.</li>
              </ul>
              <p class="font-semibold text-zinc-900 pt-2">No incluye este plan</p>
              <ul id="outExclusionsList" class="list-disc list-inside space-y-1 text-zinc-600">
                <li>Selecciona un plan para ver exclusiones.</li>
              </ul>
            </div>

            <div class="border-t pt-4 text-sm sm:text-base text-zinc-700 space-y-1">
              <p><span class="font-semibold text-zinc-900">Continuidad:</span> <span id="outContinuidad">Soporte+ mensual incluido en propuesta: $100.000 CLP/mes</span></p>
              <p><span class="font-semibold text-zinc-900">Detalle mensual:</span> $65.000 plataforma + $35.000 soporte.</p>
              <p><span class="font-semibold text-zinc-900">Importante:</span> durante los primeros 3 meses de contratacion el costo de plataforma lo asumimos nosotros. Desde el 4to mes el cliente paga la plataforma y no esta obligado a mantener el plan de soporte.</p>
            </div>

            <div class="border-t pt-4 text-sm sm:text-base text-zinc-700 space-y-1">
              <p><span class="font-semibold text-zinc-900">Condición de pago:</span> 50% de implementación al aceptar la cotización.</p>
              <p>Luego se realiza revisión de conformidad y posteriormente se cancela el 50% restante de implementación + soporte mensual (si fue incluido).</p>
            </div>

            <div class="border-t pt-4 text-sm sm:text-base text-zinc-700 space-y-2">
              <p class="font-semibold text-zinc-900">Alcance del Soporte+ (global)</p>
              <ul class="list-disc list-inside space-y-1">
                <li>Soporte tecnico continuo</li>
                <li>Hasta 20 solicitudes de cambio mensuales</li>
                <li>Ajustes operativos (textos, imagenes, estructura simple)</li>
                <li>Capacitacion inicial</li>
                <li>Atencion por WhatsApp (08:30 a 17:30)</li>
                <li>Tiempo de respuesta: hasta 30 minutos</li>
                <li>Supervision basica de funcionamiento</li>
              </ul>
            </div>

            <div class="border-t pt-4">
              <p class="text-sm font-semibold text-zinc-900 mb-2">Texto listo para enviar</p>
              <textarea id="outputTexto" class="w-full min-h-60 sm:min-h-55 border border-zinc-300 rounded-md p-3 text-sm text-zinc-700"></textarea>
              <div class="mt-3 grid grid-cols-1 sm:grid-cols-4 gap-2">
                <button id="btnCopiar" type="button" class="inline-flex items-center justify-center h-10 px-4 text-sm font-semibold bg-white text-zinc-900 border border-zinc-900 hover:bg-zinc-900 hover:text-white transition-colors">Copiar texto</button>
                <button id="btnExportarPdf" type="button" class="inline-flex items-center justify-center h-10 px-4 text-sm font-semibold bg-zinc-900 text-white border border-zinc-900 hover:bg-zinc-800 transition-colors">PDF Pro</button>
                <button id="btnExportarHtmlPdf" type="button" class="inline-flex items-center justify-center h-10 px-4 text-sm font-semibold bg-white text-zinc-900 border border-zinc-900 hover:bg-zinc-900 hover:text-white transition-colors">PDF HTML</button>
                <button id="btnLimpiar" type="button" class="inline-flex items-center justify-center h-10 px-4 text-sm font-semibold bg-white text-zinc-700 border border-zinc-300 hover:border-zinc-900 transition-colors">Limpiar</button>
              </div>
            </div>
          </div>
        </div>
      </div>
  </section>
  <CotizadorIsland client:load />
</Layout>
