---
import Layout from "@/layouts/Layout.astro";

type Plan = {
  name: string;
  price: number;
  description: string;
  features: string[];
  notIncludedByPlan: string[];
  featured?: boolean;
};

const formatClp = (amount: number) => `$${amount.toLocaleString("es-CL")} CLP`;

const shopifyPlans: Plan[] = [
  {
    name: "Plan Tienda Express",
    price: 99990,
    description: "Lanzamiento ecommerce rapido.",
    features: [
      "Productos: hasta 10",
      "Configuracion de tienda funcional",
      "Catalogo y navegacion optimizados",
      "Envios y pasarela de pago configurados",
      "Verificacion de fotografias y apoyo visual",
    ],
    notIncludedByPlan: [
      "Compra de dominio y renovaciones",
      "Costo mensual de plataforma (desde mes 4)",
      "Servicios de correo corporativo",
      "Gestion de campanas publicitarias",
      "Desarrollo personalizado avanzado",
      "Apps o licencias pagadas de terceros",
    ],
  },
  {
    name: "Plan Tienda Completa",
    price: 249990,
    description: "Base ecommerce optimizada para crecer.",
    features: [
      "Productos: hasta 20",
      "Estructura ecommerce optimizada",
      "Emails automaticos base",
      "Categorias y navegacion mejoradas",
      "Pasarela de pago incluida",
      "Configuracion de WhatsApp comercial y formulario de leads",
      "Recuperacion de carrito basica por email",
      "Capacitacion operativa inicial para el equipo",
      "Verificacion de fotografias y apoyo visual",
    ],
    notIncludedByPlan: [
      "Compra de dominio y renovaciones",
      "Costo mensual de plataforma (desde mes 4)",
      "Servicios de correo corporativo",
      "Gestion de campanas publicitarias",
      "Integraciones complejas no cotizadas",
      "Apps o licencias pagadas de terceros",
    ],
    featured: true,
  },
  {
    name: "Plan Tienda Pro",
    price: 399990,
    description: "Enfoque en conversion y operacion comercial.",
    features: [
      "Productos: hasta 50",
      "Carrito y checkout orientados a conversion",
      "Estructura comercial avanzada",
      "SEO base de tienda y productos",
      "Pasarela de pago incluida",
      "Verificacion de fotografias y apoyo visual",
    ],
    notIncludedByPlan: [
      "Compra de dominio y renovaciones",
      "Costo mensual de plataforma (desde mes 4)",
      "Servicios de correo corporativo",
      "Gestion publicitaria mensual (Meta/Google)",
      "Desarrollo de software a medida",
      "Apps o licencias pagadas de terceros",
    ],
  },
  {
    name: "Plan Tienda Elite",
    price: 649990,
    description: "Operacion ecommerce avanzada y escalable.",
    features: [
      "Productos: hasta 100",
      "Migracion base y estructura avanzada",
      "Landing pages comerciales",
      "Integraciones operativas avanzadas",
      "Pasarela de pago incluida",
      "Automatizaciones de post-compra y fidelizacion",
      "Dashboard de rendimiento comercial mensual",
      "Acompanamiento estrategico de mejoras continuas",
      "Verificacion de fotografias y apoyo visual",
    ],
    notIncludedByPlan: [
      "Compra de dominio y renovaciones",
      "Costo mensual de plataforma (desde mes 4)",
      "Servicios de correo corporativo",
      "Gestion publicitaria mensual (Meta/Google)",
      "Automatizaciones avanzadas fuera de alcance",
      "Apps o licencias pagadas de terceros",
    ],
  },
];

const wordpressPriceOverrides: Record<string, number> = {
  "Plan Tienda Completa": 549990,
  "Plan Tienda Pro": 849990,
};

const wordpressPlans: Plan[] = shopifyPlans.map((plan) => ({
  ...plan,
  price: wordpressPriceOverrides[plan.name] ?? plan.price * 2 + 100000,
  description: `${plan.description} Implementacion avanzada en hosting propio.`,
  features: [
    "Productos: sin limite",
    ...plan.features
      .filter((feature) => !feature.toLowerCase().startsWith("productos:"))
      .map((feature) =>
      feature
        .replace("Configuracion de tienda funcional", "Configuracion de tienda funcional en hosting propio")
        .replace("Estructura ecommerce optimizada", "Estructura ecommerce optimizada en hosting propio")
        .replace("Pasarela de pago incluida", "Pasarela de pago incluida y validada en hosting propio"),
    ),
    "1 servicio a eleccion gratis en la primera implementacion",
  ],
  notIncludedByPlan: plan.notIncludedByPlan
    .filter((item) => !item.toLowerCase().includes("plataforma"))
    .map((item) => item.replace(/Shopify/gi, "Hosting Propio")),
}));
---

<Layout
  title="Servicios Ecommerce | VIN Studio"
  description="Modelos ecommerce para Shopify y Hosting Propio: implementacion por plan y continuidad mensual con soporte."
  keywords="ecommerce chile, shopify chile, hosting propio ecommerce, planes ecommerce"
>
  <section class="container mx-auto px-4 py-12 sm:py-20">
    <div class="text-center max-w-4xl mx-auto mb-12 sm:mb-16">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Servicios Ecommerce: Shopify y Hosting Propio</h1>
      <p class="text-lg sm:text-xl text-zinc-600 leading-relaxed">
        Trabajamos con dos modelos para adaptarnos al nivel operativo de cada cliente. Shopify para salida rapida y un modelo de hosting propio con configuracion avanzada.
      </p>
    </div>

    <div class="mb-14 sm:mb-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-6 sm:mb-8">Planes Shopify</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5 sm:gap-6 max-w-7xl mx-auto">
        {shopifyPlans.map((plan) => (
          <article class={`border rounded-xl p-6 bg-white h-full flex flex-col ${plan.featured ? "border-zinc-900 shadow-lg shadow-zinc-900/10" : "border-zinc-200"}`}>
            {plan.featured && (
              <div class="mb-4">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] bg-zinc-900 text-white px-3 py-1 rounded-full">Mas Recomendado</span>
              </div>
            )}
            <h3 class="text-xl font-semibold text-zinc-900 mb-2">{plan.name}</h3>
            <p class="text-3xl font-bold text-zinc-900 leading-none mb-3">{formatClp(plan.price)}</p>
            <p class="text-sm text-zinc-600 mb-4">{plan.description}</p>
            <ul class="space-y-2 text-sm text-zinc-600 flex-1">
              {plan.features.map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-zinc-900"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 pt-4 border-t border-zinc-200">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500 mb-2">No incluye</p>
              <ul class="space-y-1 text-xs text-zinc-500">
                {plan.notIncludedByPlan.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-zinc-400"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <a href="/contacto" class="mt-5 inline-flex items-center justify-center h-10 w-full text-sm font-semibold border border-zinc-900 text-zinc-900 hover:bg-zinc-900 hover:text-white transition-colors">
              Solicitar este plan
            </a>
          </article>
        ))}
      </div>
    </div>

    <div class="border rounded-xl p-6 sm:p-8 bg-zinc-50 max-w-6xl mx-auto mb-16">
      <h3 class="text-2xl sm:text-3xl font-bold text-zinc-900 mb-5">Continuidad Shopify</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm sm:text-base text-zinc-600">
        <p><strong class="text-zinc-900">Soporte+ mensual:</strong> $100.000 CLP</p>
        <p><strong class="text-zinc-900">Detalle:</strong> $65.000 plataforma + $35.000 soporte</p>
        <p><strong class="text-zinc-900">Contrato:</strong> minimo 3 meses de soporte</p>
        <p><strong class="text-zinc-900">Meses 1 al 3:</strong> costo de plataforma incluido por VIN Studio</p>
        <p><strong class="text-zinc-900">Desde mes 4:</strong> cliente paga plataforma; soporte es opcional</p>
      </div>
    </div>

    <div class="mb-14 sm:mb-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-3 sm:mb-4">Planes Hosting Propio</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5 sm:gap-6 max-w-7xl mx-auto">
        {wordpressPlans.map((plan) => (
          <article class={`border rounded-xl p-6 bg-white h-full flex flex-col ${plan.featured ? "border-zinc-900 shadow-lg shadow-zinc-900/10" : "border-zinc-200"}`}>
            {plan.featured && (
              <div class="mb-4">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] bg-zinc-900 text-white px-3 py-1 rounded-full">Mas Recomendado</span>
              </div>
            )}
            <h3 class="text-xl font-semibold text-zinc-900 mb-2">{plan.name}</h3>
            <p class="text-3xl font-bold text-zinc-900 leading-none mb-3">{formatClp(plan.price)}</p>
            <p class="text-sm text-zinc-600 mb-4">{plan.description}</p>
            <ul class="space-y-2 text-sm text-zinc-600 flex-1">
              {plan.features.map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-zinc-900"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 pt-4 border-t border-zinc-200">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500 mb-2">No incluye</p>
              <ul class="space-y-1 text-xs text-zinc-500">
                {plan.notIncludedByPlan.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-zinc-400"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <a href="/contacto" class="mt-5 inline-flex items-center justify-center h-10 w-full text-sm font-semibold border border-zinc-900 text-zinc-900 hover:bg-zinc-900 hover:text-white transition-colors">
              Solicitar este plan
            </a>
          </article>
        ))}
      </div>
    </div>

    <div class="border rounded-xl p-6 sm:p-8 bg-zinc-50 max-w-6xl mx-auto mb-16">
      <h3 class="text-2xl sm:text-3xl font-bold text-zinc-900 mb-5">Continuidad Hosting Propio</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm sm:text-base text-zinc-600">
        <p><strong class="text-zinc-900">Soporte+ mensual:</strong> $35.000 CLP</p>
        <p><strong class="text-zinc-900">Detalle:</strong> solo soporte (sin cobro de plataforma)</p>
        <p><strong class="text-zinc-900">Contrato:</strong> minimo 3 meses de soporte</p>
        <p><strong class="text-zinc-900">Hosting/plataforma:</strong> mantenido y pagado por el cliente</p>
        <p><strong class="text-zinc-900">Beneficio de implementacion:</strong> 1 servicio a eleccion gratis en la primera implementacion</p>
      </div>
    </div>

    <div class="border rounded-xl p-6 sm:p-8 bg-white max-w-6xl mx-auto mb-14 sm:mb-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 mb-5">Condiciones Comerciales Generales</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm sm:text-base text-zinc-600">
        <p>Pago inicial: 50% de implementacion al aceptar cotizacion</p>
        <p>Revision de conformidad previo a cierre</p>
        <p>Pago final: 50% restante + soporte mensual</p>
        <p>Todo requerimiento fuera de alcance se cotiza por separado</p>
        <p>Servicio digital no reembolsable</p>
        <p>Al finalizar plazo contratado se entrega acceso operativo correspondiente</p>
      </div>
    </div>

    <div class="text-center">
      <a
        href="https://wa.me/56938980598?text=Hola%20VIN%20Studio%2C%20quiero%20evaluar%20planes%20ecommerce%20Shopify%20y%20Hosting%20Propio."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center h-11 w-full sm:w-auto px-8 text-sm font-semibold bg-zinc-900 text-white border border-zinc-900 hover:bg-zinc-800 transition-colors"
      >
        Solicitar propuesta
      </a>
    </div>
  </section>
</Layout>
